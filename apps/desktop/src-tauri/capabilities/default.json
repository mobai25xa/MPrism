{
  "$schema": "https://schema.tauri.app/config/2/capability",
  "identifier": "default",
  "description": "Minimal capabilities for the MPrism main window. Network to model providers is Rust-only; frontend may only open http(s)/mailto links via opener.",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:window:allow-show",
    "core:window:allow-set-focus",
    "core:window:allow-unminimize",
    {
      "identifier": "opener:allow-open-url",
      "allow": [
        { "url": "https://*" },
        { "url": "http://*" },
        { "url": "mailto:*" }
      ]
    }
  ]
}
